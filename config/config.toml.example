# PwnBullseye4 User Configuration
# Copy this file to /etc/pwnagotchi/config.toml and edit as needed
# All settings here override defaults.toml

main.name = "my-pwnbullseye4"
main.lang = "en"
main.plugins.wpa-sec.enabled = true
main.plugins.wpa-sec.api_key = "YOUR_WPA_SEC_API_KEY_HERE"

# AI settings
ai.enabled = true
ai.path = "/root/brain.onnx"

# Display - Waveshare v4 (2.13" e-Paper HAT v4)
ui.display.type = "waveshare_4"
ui.display.rotation = 0
ui.display.color = "auto"
ui.display.invert = true

# Web UI
ui.web.enabled = true
ui.web.username = "changeme"
ui.web.password = "changeme"
ui.web.port = 8080

# Bluetooth tethering (configure for your phone)
# main.plugins.bt-tether.enabled = true
# main.plugins.bt-tether.devices.my-phone.enabled = true
# main.plugins.bt-tether.devices.my-phone.mac = "AA:BB:CC:DD:EE:FF"
# main.plugins.bt-tether.devices.my-phone.ip = "192.168.44.44"

# GPS (optional)
# main.plugins.gps.enabled = true
# main.plugins.gps.device = "/dev/ttyUSB0"

# Battery monitoring (optional - uncomment for your UPS)
# main.plugins.pisugar2.enabled = true
# main.plugins.ups_lite.enabled = true

# Personality
personality.deauth = true
personality.associate = true
personality.channels = [1, 6, 11]